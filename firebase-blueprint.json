{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator user for the backend",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's drink order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "customerName", "customerPhone", "items", "totalPrice", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "List of authorized administrators by UID"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer drink orders"
    }
  }
}
